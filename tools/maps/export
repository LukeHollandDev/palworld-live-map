#!/bin/sh
set -eu

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
repo_dir=$(CDPATH= cd -- "$script_dir/../.." && pwd)
default_crossover_root="$HOME/Library/Application Support/CrossOver/Bottles/Steam/drive_c/Program Files (x86)/Steam/steamapps/common/Palworld"
palworld_root=${PALWORLD_ROOT:-$default_crossover_root}
output_dir=${MAP_OUTPUT_DIR:-$repo_dir/build/maps}
game_version=${PALWORLD_GAME_VERSION:-unknown}
mapping_commit=42cf396e714c166f17950a9c964583e0cadf2a15
mapping_sha256=241c45de9d5b55b246cd4b39d62b9209faf7758ce0637e1f7a545aa0f75f71f0
cache_dir=${MAP_EXPORT_CACHE_DIR:-$repo_dir/build/map-exporter-cache}
mapping_file="$cache_dir/Mappings-$mapping_commit.usmap"
pak_dir="$palworld_root/Pal/Content/Paks"

if [ ! -d "$pak_dir" ]; then
  printf 'Palworld PAK directory not found: %s\n' "$pak_dir" >&2
  printf 'Set PALWORLD_ROOT to the directory containing Pal/ and Engine/.\n' >&2
  exit 1
fi

mkdir -p "$cache_dir" "$output_dir"
if [ ! -f "$mapping_file" ]; then
  curl -fsSL "https://raw.githubusercontent.com/PalworldModding/UsefulFiles/$mapping_commit/Mappings.usmap" -o "$mapping_file"
fi
actual_mapping_sha256=$(shasum -a 256 "$mapping_file" | awk '{print $1}')
if [ "$actual_mapping_sha256" != "$mapping_sha256" ]; then
  printf 'Mappings checksum mismatch: got %s\n' "$actual_mapping_sha256" >&2
  exit 1
fi

docker build --quiet -t palworld-live-map/map-exporter:dev "$repo_dir/tools/map-exporter" >/dev/null
docker run --rm \
  --mount "type=bind,src=$pak_dir,dst=/palworld-paks,readonly" \
  --mount "type=bind,src=$mapping_file,dst=/mappings.usmap,readonly" \
  --mount "type=bind,src=$output_dir,dst=/output" \
  palworld-live-map/map-exporter:dev \
  --pak-directory /palworld-paks \
  --mappings /mappings.usmap \
  --output /output \
  --game-version "$game_version"

printf 'Generated maps and provenance manifest in %s\n' "$output_dir"

