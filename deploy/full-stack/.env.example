# Required. Use one long, random value; it is shared only between the two containers.
ADMIN_PASSWORD=replace-with-a-long-random-value

# Server identity and player access.
SERVER_NAME=Palworld with Live Map
SERVER_DESCRIPTION=A self-hosted Palworld dedicated server
SERVER_PASSWORD=replace-with-a-player-password
PLAYERS=16
COMMUNITY=false
CROSSPLAY_PLATFORMS=(Steam,Xbox,PS5,Mac)

# Host ports. The private REST API port 8212 is deliberately not published.
PALWORLD_PORT=8211
QUERY_PORT=27015
HTTP_PORT=8080

# Container file ownership and timezone.
PUID=1000
PGID=1000
TZ=Europe/London

