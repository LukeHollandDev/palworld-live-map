# Palworld REST API base URL as reachable from the live-map process or container.
# Compose maps host.docker.internal to the Docker host on Linux.
PALWORLD_REST_URL=http://host.docker.internal:8212

# Palworld REST API admin password. This stays in the backend and is never sent to browsers.
PALWORLD_ADMIN_PASSWORD=replace-me

# Run with fictional data and without a Palworld server. When true, the two settings above are optional.
DEMO_MODE=false

# Host port published by Compose for the live-map website.
HTTP_PORT=8080

# Address the Go HTTP server listens on. Keep :8080 when using Compose.
ADDR=:8080

# Optional healthcheck override. By default the binary derives this from ADDR.
# Set this only when a proxy or unusual network namespace requires another URL.
# HEALTHCHECK_URL=http://127.0.0.1:8080/-/health

# How often the online-player list is refreshed. Minimum: 2s.
POLL_INTERVAL=5s

# Timeout for player and server-information requests. Must be shorter than POLL_INTERVAL.
UPSTREAM_TIMEOUT=4s

# Whether to poll the optional game-data endpoint for bases, Pals, and NPCs.
WORLD_DATA_ENABLED=true

# How often world objects are refreshed when WORLD_DATA_ENABLED is true. Minimum: 5s.
WORLD_POLL_INTERVAL=15s

# Timeout for the larger world-object snapshot. Must be shorter than WORLD_POLL_INTERVAL.
WORLD_TIMEOUT=10s
